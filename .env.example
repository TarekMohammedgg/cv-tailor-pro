# ============================================
# CV Tailor Pro — Environment Variables
# ============================================
# Set these in Vercel (Settings → Environment Variables)
# so users don't need to configure anything except their API key.
#
# These are YOUR (site owner) credentials, NOT the user's.
# ============================================

# Supabase — for saving CV history & PDFs
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...your-anon-key

# Edge Function URL — only needed if you want to support OpenAI/Claude
# (Gemini works without this)
VITE_EDGE_FUNCTION_URL=https://your-project.supabase.co/functions/v1/generate-cv
